<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <link rel="stylesheet" href="/public/styles.css">
</head>
<body class="admin-page <%= (data && data.pageClass) ? data.pageClass : '' %>">
  <header class="topnav">
    <div><strong>EPSILOCK Main Node</strong></div>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/users">Users</a>
      <a href="/admin/rooms">Rooms</a>
      <a href="/admin/nodes">Nodes</a>
      <a href="/admin/incidents">Incidents</a>
      <a href="/admin/attacker-demo">Attacker Demo</a>
      <a href="/admin/security-settings">Security Settings</a>
    </nav>
    <form method="post" action="/logout"><button type="submit">Logout</button></form>
  </header>
  <main class="container">
    <%- include(bodyView, data || {}) %>
  </main>
  <script>window.__ADMIN_TOKEN = '<%= (data && data.admin && data.admin.token) ? data.admin.token : '' %>';</script>
  <script src="/public/admin.js"></script>
</body>
</html>
