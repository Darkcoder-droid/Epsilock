MONGO_URI=mongodb://127.0.0.1:27017/epsilock_demo
JWT_SECRET=replace_with_long_secret
ACCESS_TOKEN_TTL=10m

# TLS / HTTPS / WSS
TLS_KEY_PATH=./certs/localhost-key.pem
TLS_CERT_PATH=./certs/localhost-cert.pem

# Main / User node ports
MAIN_NODE_PORT=8443
USER_NODE_1_PORT=3001
USER_NODE_2_PORT=3002
USER_NODE_PORT=3001
ATTACKER_NODE_PORT=4001
MAIN_NODE_WSS_URL=wss://localhost:8443/ws
ATTACKER_NODE_URL=https://localhost:4001/attacker

# User node identity
NODE_ID=NODE-1

# Cover traffic demo
ATTACKER_DEMO_ENABLED=true
ATTACKER_DEMO_TOKEN=change-this-demo-token
COVER_TRAFFIC_ENABLED=false
COVER_TRAFFIC_INTERVAL_MS=1500
COVER_TRAFFIC_JITTER_MS=1000
COVER_TRAFFIC_PACKET_MIN_BYTES=256
COVER_TRAFFIC_PACKET_MAX_BYTES=1024
COVER_TRAFFIC_RATIO=3

# Anomaly thresholds
ALLOWED_ORIGINS=https://localhost:8443,https://localhost:3001,https://localhost:3002,https://localhost:4001,http://localhost:8443,http://localhost:3001,http://localhost:3002,http://localhost:4001
MAX_MESSAGES_PER_10_SECONDS=20
MAX_WS_EVENTS_PER_5_SECONDS=40
MAX_WS_PAYLOAD_BYTES=65536
DISCONNECT_ANOMALY_LIMIT=6
DISCONNECT_ANOMALY_WINDOW_SECONDS=60

# Demo AES key (hex-64 preferred; plain string also accepted in demo mode)
DEMO_SHARED_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
