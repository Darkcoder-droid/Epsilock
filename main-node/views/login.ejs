<div class="login-auth-container">
  <div class="login-premium-card cascading-item">

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="login-alert">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form method="post" action="/login" id="loginForm" class="premium-form">
      <div class="input-field">
        <label>USERNAME</label>
        <div class="input-row">
          <i class="fa-solid fa-id-badge"></i>
          <input name="username" required placeholder="Enter username" autocomplete="off">
        </div>
      </div>

      <div class="input-field">
        <label>PASSWORD</label>
        <div class="input-row">
          <i class="fa-solid fa-key"></i>
          <input type="password" name="password" required placeholder="••••••••" autocomplete="off">
        </div>
      </div>

      <button type="submit" id="loginBtn" class="login-trigger">
        <span>AUTHORIZE SESSION</span>
        <i class="fa-solid fa-arrow-right"></i>
      </button>
    </form>
  </div>
</div>

<script>
  document.getElementById('loginForm')?.addEventListener('submit', function() {
    const btn = document.getElementById('loginBtn');
    if (btn) {
      btn.innerHTML = '<span>AUTHORIZING...</span><i class="fa-solid fa-circle-notch fa-spin"></i>';
      btn.style.backgroundSize = '400% 400%';
    }
  });
</script>
